{
  "name": "freedom",
  "productName": "iLink",
  "version": "0.0.0",
  "description": "iLink - a Windows LAN P2P encrypted messenger",
  "private": true,
  "author": "iLink",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Check-Now/iLink.git"
  },
  "bugs": {
    "url": "https://github.com/Check-Now/iLink/issues"
  },
  "homepage": "https://github.com/Check-Now/iLink#readme",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,green \"vite\" \"wait-on tcp:127.0.0.1:5173 && cross-env NODE_ENV=development electron .\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:127.0.0.1:5173 && cross-env NODE_ENV=development electron .",
    "dev:second": "wait-on tcp:127.0.0.1:5173 && cross-env NODE_ENV=development FREEDOM_DATA_DIR=data-2 electron .",
    "build": "vite build",
    "test": "node --test",
    "preview": "vite preview",
    "start": "cross-env NODE_ENV=production electron .",
    "pack:dir": "npm run build && electron-builder --win --dir",
    "dist": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.freedom.lan",
    "productName": "iLink",
    "electronDist": "node_modules/electron/dist",
    "artifactName": "Freedom.${ext}",
    "files": ["dist/**", "electron/**", "icon.png", "package.json"],
    "directories": { "output": "release" },
    "win": { "icon": "build/icon.png", "target": ["zip"], "signAndEditExecutable": false }
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.4",
    "vite": "^5.2.0",
    "wait-on": "^7.2.0"
  }
}
